<% layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-6">
    <div class="col-md-6">
        <h1 class="text-center mb-4">Edit Campground</h1>

        <form
                action="/campgrounds/<%= campground._id %>?_method=PUT"
                method="POST"
                enctype="multipart/form-data"
                novalidate
                class="form-validate"
        >

            <div class="mb-3">
                <label class="form-label">Title</label>
                <input name="campground[title]" class="form-control" value="<%= campground.title %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Location</label>
                <input name="campground[location]" class="form-control" value="<%= campground.location %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Price</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input name="campground[price]" type="number" step="0.01" class="form-control" value="<%= campground.price %>" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="campground[description]" rows="3" class="form-control"><%= campground.description %></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Add Images</label>
                <input type="file" name="image" multiple class="form-control">
            </div>

            <% if (campground.images && campground.images.length) { %>
                <div class="mb-3">
                    <% campground.images.forEach(img => { %>
                        <img src="<%= img.url %>" class="img-thumbnail me-2 mb-2" style="width:100px;">
                    <% }) %>
                </div>
            <% } %>

            <div class="d-grid gap-2 mb-3">
                <button class="btn btn-warning">Update Campground</button>
            </div>

            <a href="/campgrounds/<%= campground._id %>" class="btn btn-secondary">Back</a>

        </form>
    </div>
</div>

<script>
    (() => {
        'use strict';
        const forms = document.querySelectorAll('.form-validate');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            });
        });
    })();
</script>
